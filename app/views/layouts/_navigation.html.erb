<nav class="flex flex-col md:flex-row items-center justify-between flex-wrap bg-clever p-6">
  <div class="flex items-center flex-shrink-0 text-white mr-6">
    <%=image_tag "logo.svg", alt: "CleverSnap Logo", class: "w-8 h-8 mr-2" %>
    <span class="font-semibold text-xl tracking-tight">CleverSnap</span>
  </div>
  
  <div>
    <% if user_signed_in? %>
      <div class="flex flex-col md:flex-row gap-4 items-center text-white">
        <span class="text-sm md:text-base">Welcome, <%= current_user.email %></span>
        <%= button_to "Log out", destroy_user_session_path,
          method: :delete,
          class: "bg-white text-gray-800 font-semibold py-2 px-4 rounded inline-flex items-center cursor-pointer" %>
      </div>
    <% end %>
  </div>
</nav>

