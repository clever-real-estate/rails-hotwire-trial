<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Photo Gallery" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Photo Gallery">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%= favicon_link_tag "logo.svg", rel: "icon", type: "image/svg+xml" %>
    <%= favicon_link_tag "logo.svg", rel: "apple-touch-icon", type: "image/svg+xml" %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= render "layouts/header" %>
    
    <section id="content">
      <%= yield %>
    </section>
  </body>
</html>
