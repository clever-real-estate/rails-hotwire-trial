<!DOCTYPE html>
<html lang="en">
  <head>
    <title>Photo Gallery</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <a href="<%= root_path %>" class="site-header__logo-link">
        <%= image_tag "logo.svg", alt: "Clever", class: "site-header__logo" %>
      </a>
      <% if current_user %>
        <div class="site-header__user">
          <span class="site-header__name"><%= current_user.name %></span>
          <%= button_to "Sign Out", logout_path, method: :delete, class: "btn btn--ghost" %>
        </div>
      <% end %>
    </header>

    <% if notice %>
      <div class="flash flash--notice" role="alert"><%= notice %></div>
    <% end %>
    <% if alert %>
      <div class="flash flash--alert" role="alert"><%= alert %></div>
    <% end %>

    <main class="main-content">
      <%= yield %>
    </main>
  </body>
</html>
