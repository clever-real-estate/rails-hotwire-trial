<div class="min-h-screen bg-slate-100 flex items-center justify-center px-4">
  <div class="w-full max-w-md rounded-lg border border-slate-200 bg-white p-8 shadow-sm">
    <h1 class="text-2xl font-semibold text-slate-900">Log in</h1>
    <p class="mt-1 text-sm text-slate-500">Welcome back to Photo Gallery</p>

    <%= form_with scope: :session, url: session_path, class: "mt-6 space-y-5" do |form| %>
      <div>
        <%= form.label :username, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= form.text_field :username, placeholder: "Username", required: true, class: "w-full rounded-md border border-slate-300 px-3 py-2 text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>

      <div>
        <%= form.label :password, class: "mb-1 block text-sm font-medium text-slate-700" %>
        <%= form.password_field :password, placeholder: "Password", required: true, class: "w-full rounded-md border border-slate-300 px-3 py-2 text-slate-900 placeholder:text-slate-400 focus:border-slate-500 focus:outline-none focus:ring-2 focus:ring-slate-200" %>
      </div>

      <div>
        <%= form.submit "Log in", class: "w-full rounded-md bg-slate-900 px-4 py-2 font-medium text-white transition hover:bg-slate-800 focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2" %>
      </div>
    <% end %>
  </div>
</div>
