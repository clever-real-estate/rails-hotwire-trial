<%# app/views/devise/sessions/new.html.erb %>
<div class="min-vh-100 d-flex align-items-center justify-content-center bg-light">
  <div class="card shadow-sm" style="width: 100%; max-width: 420px;">
    <div class="card-body p-4">
      <div class="text-center mb-4">
        <%= image_tag "logo.svg", height: 40, alt: "Logo" %>
      </div>
      <h1 class="h5 text-center mb-4 fw-semibold">Sign in to your account</h1>
      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="mb-3">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "you@example.com" %>
        </div>
        <div class="mb-3">
          <%= f.label :password, class: "form-label" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "form-control", placeholder: "••••••••" %>
        </div>
        <%= f.submit "Sign in", class: "btn btn-dark w-100" %>
      <% end %>
    </div>
  </div>
</div>
