<div id="photo_<%= photo.id %>_like" class="d-flex align-items-center gap-1" data-controller="like" data-like-liked-class="liked">
  <% if liked %>
    <%= button_to photo_like_path(photo),
          method: :delete,
          form: { class: "d-inline-flex align-items-center m-0", data: { turbo_stream: true } },
          class: "btn btn-link p-0 border-0",
          aria: { label: "Unlike photo" },
          data: { action: "like#toggle", like_target: "button" } do %>
      <%= image_tag "star-fill.svg", width: 20, height: 20, alt: "liked" %>
    <% end %>
  <% else %>
    <%= button_to photo_like_path(photo),
          method: :post,
          form: { class: "d-inline-flex align-items-center m-0", data: { turbo_stream: true } },
          class: "btn btn-link p-0 border-0",
          aria: { label: "Like photo" },
          data: { action: "like#toggle", like_target: "button" } do %>
      <%= image_tag "star-line.svg", width: 20, height: 20, alt: "not liked" %>
    <% end %>
  <% end %>
  <span class="small text-muted d-inline-flex align-items-center" data-like-target="count">
    <%= photo.likes_count %>
  </span>
</div>
