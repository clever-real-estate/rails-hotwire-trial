<article class="photo-card" id="<%= dom_id(photo) %>">
  <% if photo.source_url.present? %>
    <a href="<%= photo.source_url %>" target="_blank" rel="noopener noreferrer" class="photo-card__image-wrapper">
      <img src="<%= photo.src_medium %>"
           alt="<%= photo.alt.presence || "Photo by #{photo.photographer}" %>"
           class="photo-card__image"
           loading="lazy">
    </a>
  <% else %>
    <div class="photo-card__image-wrapper">
      <img src="<%= photo.src_medium %>"
           alt="<%= photo.alt.presence || "Photo by #{photo.photographer}" %>"
           class="photo-card__image"
           loading="lazy">
    </div>
  <% end %>
  <div class="photo-card__footer">
    <div class="photo-card__meta">
      <span class="photo-card__photographer"><%= photo.photographer %></span>
      <% if photo.source_url.present? %>
        <a href="<%= photo.source_url %>"
           target="_blank"
           rel="noopener noreferrer"
           class="photo-card__source-link"
           aria-label="View on Pexels">
          <%= image_tag "links.svg", class: "icon", alt: "" %>
        </a>
      <% end %>
    </div>
    <%= render "likes/like_button", photo: photo %>
  </div>
</article>
