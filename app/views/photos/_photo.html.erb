<div class="col">
  <div class="card h-100 shadow-sm">
    <img src="<%= photo.image_url %>" alt="<%= photo.title %>" class="card-img-top" loading="lazy">
    <div class="card-body d-flex flex-column gap-2">
      <p class="card-text fw-semibold mb-0"><%= photo.photographer_name %></p>
      <div class="mt-auto d-flex align-items-center justify-content-between">
        <a href="<%= photo.source_url %>"
           target="_blank"
           rel="noopener noreferrer"
           class="source-link text-muted text-decoration-none position-relative"
           aria-label="View source">
          <%= image_tag "links.svg", width: 18, height: 18, alt: "" %>
          <span class="tooltip position-absolute top-100 start-50 translate-middle-x mt-1 px-2 py-1 bg-dark text-white rounded" role="tooltip">
            View Source
          </span>
        </a>
        <div class="d-flex align-items-center gap-1">
          <%= image_tag "star-line.svg", width: 20, height: 20, alt: "like" %>
          <span class="small text-muted"><%= photo.likes_count %></span>
        </div>
      </div>
    </div>
  </div>
</div>
