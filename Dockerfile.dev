# Development Dockerfile - optimized for faster builds and easier debugging
ARG RUBY_VERSION=4.0.2
FROM ruby:$RUBY_VERSION-slim

WORKDIR /rails

# Install development and runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
  build-essential \
  git \
  curl \
  libvips \
  libyaml-dev \
  pkg-config \
  sqlite3 \
  nodejs \
  yarn \
  && rm -rf /var/lib/apt/lists/*

# Set environment
ENV RAILS_ENV=development \
    BUNDLE_PATH=/bundle

# Install bundler
RUN gem install bundler

# Expose ports for Rails server and asset compilation
EXPOSE 3000 3035

CMD ["bin/dev"]
