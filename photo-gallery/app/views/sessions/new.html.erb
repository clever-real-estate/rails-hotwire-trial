<h1>Sign In</h1>

<%= form_with url: sign_in_path, method: :post, local: true do |form| %>
  <div class="form-group">
    <%= form.label :email %>
    <%= form.email_field :email, required: true %>
  </div>

  <div class="form-group">
    <%= form.label :password %>
    <%= form.password_field :password, required: true %>
  </div>

  <%= form.submit "Sign In", class: "btn" %>
<% end %>

<% if flash[:alert] %>
  <p class="flash"><%= flash[:alert] %></p>
<% end %>