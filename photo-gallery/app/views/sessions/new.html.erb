<div class="login-container">
  <h1>Sign In</h1>

  <%= form_with url: sign_in_path, local: true, class: "login-form" do |f| %>
    <div class="form-group">
      <%= f.label :email %>
      <%= f.email_field :email, autofocus: true %>
    </div>

    <div class="form-group">
      <%= f.label :password %>
      <%= f.password_field :password %>
    </div>

    <%= f.submit "Sign In", class: "btn-submit" %>
  <% end %>
</div>