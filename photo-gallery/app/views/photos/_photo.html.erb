<article class="photo-card">
  <%= image_tag photo.src_medium, alt: photo.alt, class: "photo" %>
  <footer class="photo-meta">
    <span class="photographer"><%= photo.photographer %></span>
    <div class="photo-actions">
      <%= link_to photo.source_url, target: "_blank", rel: "noopener", class: "source-link", "aria-label": "View source on Pexels" do %>
        <%= image_tag "links.svg", alt: "" %>
      <% end %>
      <span class="star-placeholder">
        <%= image_tag "star-line.svg", alt: "" %>
        <%= photo.likes_count %>
      </span>
    </div>
  </footer>
</article>
